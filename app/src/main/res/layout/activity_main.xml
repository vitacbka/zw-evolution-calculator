<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/kanagawa_bg"
            android:fillViewport="true">

    <!-- 🔥 ИСПРАВЛЕНО: убран комментарий внутри тега, добавлен layout_width -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧟 ZOMBIE WAVES EVO CALC 🧟"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/kanagawa_accent"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <!-- Выбор дня -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_day"
            android:textSize="16sp"
            android:textColor="@color/kanagawa_text"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/daySpinner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/kanagawa_surface"
            android:popupBackground="@color/kanagawa_surface"
            android:layout_marginBottom="20dp" />

        <!-- Контейнер для динамических полей ввода -->
        <LinearLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp" />

        <!-- Кнопка расчета -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/calculateButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/calculate"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/kanagawa_accent"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearAllButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/clear_all"
            android:textSize="16sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="12dp"
            app:strokeColor="@color/kanagawa_accent"
            android:textColor="@color/kanagawa_accent"
            android:layout_marginBottom="20dp" />

        <!-- Результат -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/kanagawa_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kanagawa_accent"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/resultTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Результат"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/kanagawa_accent"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/kanagawa_text"
                    android:lineSpacingExtra="4dp" />

                <!-- Аккордеон 1: Разверните, чтобы посмотреть текущие награды -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rewardsAccordionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/kanagawa_bg_secondary"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/kanagawa_surface"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Заголовок аккордеона -->
                        <LinearLayout
                            android:id="@+id/rewardsAccordionHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="📦 Разверните, чтобы посмотреть текущие награды"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/kanagawa_green" />

                            <ImageView
                                android:id="@+id/rewardsAccordionIcon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_expand_more"
                                android:contentDescription="Expand" />
                            </LinearLayout>

                            <!-- Контент аккордеона -->
                            <LinearLayout
                                android:id="@+id/rewardsAccordionContent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:visibility="gone">

                                <!-- Количество очков -->
                                <TextView
                                    android:id="@+id/pointsText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Количество очков: 0"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/kanagawa_accent"
                                    android:layout_marginBottom="8dp" />

                                <!-- Вероятности для Дня 6 -->
                                <TextView
                                    android:id="@+id/day6ProbabilitiesText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="@color/kanagawa_blue"
                                    android:lineSpacingExtra="3dp"
                                    android:layout_marginBottom="8dp"
                                    android:visibility="gone" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Награды с учетом набранных очков:"
                                    android:textSize="14sp"
                                    android:textColor="@color/kanagawa_text"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="8dp" />

                                <!-- 🔥 ИСПРАВЛЕНО: LinearLayout вместо RecyclerView -->
                                <LinearLayout
                                    android:id="@+id/rewardsImagesContainer"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />

                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Аккордеон 2: Нажмите, чтобы посмотреть награды за топ -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/topRewardAccordionCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="gone"
                            app:cardBackgroundColor="@color/kanagawa_bg_secondary"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/kanagawa_accent"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <!-- Заголовок аккордеона -->
                                <LinearLayout
                                    android:id="@+id/topRewardAccordionHeader"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:padding="12dp"
                                    android:gravity="center_vertical"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:background="?attr/selectableItemBackground">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="🏆 Нажмите, чтобы посмотреть награды за топ"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/kanagawa_yellow" />

                                    <ImageView
                                        android:id="@+id/topRewardAccordionIcon"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_expand_more"
                                        android:contentDescription="Expand" />
                                    </LinearLayout>

                                    <!-- Контент аккордеона -->
                                    <LinearLayout
                                        android:id="@+id/topRewardAccordionContent"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:padding="12dp"
                                        android:visibility="gone">

                                        <ImageView
                                            android:id="@+id/topRewardImage"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:adjustViewBounds="true"
                                            android:scaleType="fitCenter"
                                            android:contentDescription="Top Reward" />
                                        </LinearLayout>
                                    </LinearLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Футер с YooMoney -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/kanagawa_surface"
                            android:layout_marginTop="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="16dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="☕ "
                                android:textSize="20sp"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/footer_text"
                                android:textSize="12sp"
                                android:textColor="@color/kanagawa_text_dim"
                                android:layout_marginBottom="12dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/donateYoomoneyButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="40dp"
                                    android:text="YooMoney"
                                    android:textSize="13sp"
                                    android:textColor="@color/kanagawa_white"
                                    app:cornerRadius="8dp"
                                    app:backgroundTint="@color/kanagawa_green_dark"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    app:strokeColor="@color/kanagawa_green_dark"
                                    android:layout_marginEnd="8dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/donateSberButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="40dp"
                                    android:text="SberBank"
                                    android:textSize="13sp"
                                    android:textColor="@color/kanagawa_white"
                                    app:cornerRadius="8dp"
                                    app:backgroundTint="@color/kanagawa_green_dark"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    app:strokeColor="@color/kanagawa_green_dark" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </ScrollView>
