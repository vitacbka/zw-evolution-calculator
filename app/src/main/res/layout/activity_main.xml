<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kanagawa_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Evo Calc"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/kanagawa_accent"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <!-- Выбор дня -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_day"
            android:textSize="16sp"
            android:textColor="@color/kanagawa_text"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/daySpinner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/kanagawa_surface"
            android:popupBackground="@color/kanagawa_surface"
            android:layout_marginBottom="24dp" />

        <!-- Контейнер для динамических полей ввода -->
        <LinearLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp" />

        <!-- Кнопка расчета -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/calculateButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/calculate"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/kanagawa_accent"
            android:layout_marginBottom="20dp" />

        <!-- Результат -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/kanagawa_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kanagawa_accent"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/resultTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Результат"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/kanagawa_accent"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/kanagawa_text"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:id="@+id/rewardsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/kanagawa_green"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="3dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Футер с YooMoney -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/kanagawa_surface"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ "
                android:textSize="20sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/footer_text"
                android:textSize="12sp"
                android:textColor="@color/kanagawa_text_dim"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/donateYoomoneyButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="YooMoney"
                    android:textSize="13sp"
                    android:textColor="@color/kanagawa_white"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/kanagawa_green_dark"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/kanagawa_green_dark"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/donateSberButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="SberBank"
                    android:textSize="13sp"
                    android:textColor="@color/kanagawa_white"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/kanagawa_green_dark"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/kanagawa_green_dark" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
